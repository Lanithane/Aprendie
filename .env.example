# --- Server config ---
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# --- Database ---
# Two URLs, selected by NODE_ENV (see server/env.ts): development/test use
# DATABASE_URL_LOCAL, production uses DATABASE_URL (also the var Railway injects).
# For local dev you only need DATABASE_URL_LOCAL; set DATABASE_URL to the prod
# connection string if you want to target prod from your machine (db:migrate:prod).
DATABASE_URL=
DATABASE_URL_LOCAL=postgresql://postgres:postgres@localhost:5432/aprendie

# --- Sessions ---
# Generate a 32+ char random string. e.g. `openssl rand -base64 48`
SESSION_SECRET=replace-me-with-a-long-random-string

# --- Anthropic (operator key) ---
# The single key all approved users spend against. Required for any spend path
# (sentence generation, grading, translation); unset is fine for non-spend local work.
OPERATOR_ANTHROPIC_KEY=

# --- Google OAuth ---
# From console.cloud.google.com → APIs & Services → Credentials → OAuth client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- RBAC ---
# The account whose email matches this is promoted to `admin` on login.
# Leave unset for no auto-promoted admin.
ADMIN_EMAIL=

# --- Superadmin email notifications (Resend) ---
# RESEND_API_KEY: from resend.com → API Keys. SUPERADMIN_EMAIL: the single operator
# inbox that gets ops alerts (e.g. new signup awaiting approval). Both unset = no emails
# sent (server still boots, logs a warn). RESEND_FROM defaults to onboarding@resend.dev,
# which needs no domain verification but only delivers to your Resend account's own email
# — fine for superadmin alerts. Set it to a verified-domain sender (e.g.
# "Aprendie <noreply@aprendie.com>") once you verify the domain in Resend.
RESEND_API_KEY=
SUPERADMIN_EMAIL=
# RESEND_FROM=Aprendie <onboarding@resend.dev>
