# --- Server config ---
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# --- Database ---
# Two URLs, selected by NODE_ENV (see server/env.ts): development/test use
# DATABASE_URL_LOCAL, production uses DATABASE_URL (also the var Railway injects).
# For local dev you only need DATABASE_URL_LOCAL; set DATABASE_URL to the prod
# connection string if you want to target prod from your machine (db:migrate:prod).
DATABASE_URL=
DATABASE_URL_LOCAL=postgresql://postgres:postgres@localhost:5432/aprendie

# --- Sessions ---
# Generate a 32+ char random string. e.g. `openssl rand -base64 48`
SESSION_SECRET=replace-me-with-a-long-random-string

# --- Encryption for stored Anthropic API keys ---
# Must be 32 random bytes, base64-encoded. e.g. `openssl rand -base64 32`
ENCRYPTION_KEY=replace-me-with-base64-32-bytes

# --- Google OAuth ---
# From console.cloud.google.com → APIs & Services → Credentials → OAuth client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- RBAC ---
# The account whose email matches this is promoted to `admin` on login.
# Leave unset for no auto-promoted admin.
ADMIN_EMAIL=
